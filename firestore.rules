rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /stores/{storeId}/estimateSimulator/config {
      allow read: if resource.data.enabled == true
        || (request.auth != null && request.auth.token.admin == true);
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    match /stores/{storeId}/estimateCounters/{dateKey} {
      allow read: if true;
      allow create, update: if request.resource.data.count is int
        && request.resource.data.count > 0
        && request.resource.data.count <= 9999;
    }

    match /stores/{storeId}/estimateHistory/{estimateId} {
      allow create: if request.resource.data.estimateNumber is string
        && request.resource.data.estimateNumber.size() > 0
        && request.resource.data.createdAt is string
        && request.resource.data.total is number;
      allow read, update, delete: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
