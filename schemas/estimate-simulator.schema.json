{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://infochibafukushi-dotcom.github.io/lp-site/schemas/estimate-simulator.schema.json",
  "title": "EstimateSimulatorConfig",
  "type": "object",
  "required": ["enabled", "version", "page", "basicFees", "distancePricing", "categories"],
  "properties": {
    "enabled": { "type": "boolean" },
    "version": { "type": "number" },
    "updatedAt": { "type": "string" },
    "page": {
      "type": "object",
      "required": ["title", "description", "disclaimer"],
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "disclaimer": { "type": "string" },
        "resultNotes": { "type": "string" },
        "distanceLabel": { "type": "string" },
        "distanceNote": { "type": "string" },
        "preFixedFareNotice": { "type": "string" },
        "tollRoadNote": { "type": "string" }
      },
      "additionalProperties": true
    },
    "basicFees": { "type": "object" },
    "distancePricing": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["patternA", "patternB"] },
        "patternA": { "type": "object" },
        "patternB": { "type": "object" }
      },
      "additionalProperties": true
    },
    "fareMode": {
      "type": "string",
      "enum": ["time", "distance", "distance_time", "pre_fixed_fare"]
    },
    "fareModeOptions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "enabled": { "type": "boolean" }
        },
        "required": ["id", "label"],
        "additionalProperties": true
      }
    },
    "fareComponents": {
      "type": "object"
    },
    "categories": {
      "type": "object",
      "required": ["mobility", "assistance", "stairAssist", "tripType", "roundTripAddon"],
      "properties": {
        "mobility": { "$ref": "#/definitions/category" },
        "assistance": { "$ref": "#/definitions/category" },
        "stairAssist": { "$ref": "#/definitions/category" },
        "tripType": { "$ref": "#/definitions/tripCategory" },
        "roundTripAddon": { "$ref": "#/definitions/tripCategory" }
      },
      "additionalProperties": true
    },
    "waitingFees": { "type": "object" },
    "googleMaps": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "apiKey": { "type": "string" },
        "language": { "type": "string" },
        "region": { "type": "string" }
      },
      "additionalProperties": true
    },
    "options": { "type": "object" },
    "mappings": { "type": "object" },
    "resultLabels": { "type": "object" },
    "pdfFooter": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "businessName": { "type": "string" },
        "phone": { "type": "string" },
        "homepageUrl": { "type": "string" },
        "homepageQrLabel": { "type": "string" },
        "lineUrl": { "type": "string" },
        "lineQrLabel": { "type": "string" },
        "message": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "definitions": {
    "categoryItem": {
      "type": "object",
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "visible": { "type": "boolean" },
        "order": { "type": "number" }
      },
      "additionalProperties": true
    },
    "tripTypeItem": {
      "allOf": [
        { "$ref": "#/definitions/categoryItem" },
        {
          "type": "object",
          "properties": {
            "distanceMultiplier": { "type": "number", "exclusiveMinimum": 0 },
            "waitingFeeRef": { "type": "string" },
            "escortFeeRef": { "type": "string" }
          },
          "additionalProperties": true
        }
      ]
    },
    "category": {
      "type": "object",
      "required": ["items"],
      "properties": {
        "label": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/definitions/categoryItem" }
        }
      },
      "additionalProperties": true
    },
    "tripCategory": {
      "type": "object",
      "required": ["items"],
      "properties": {
        "label": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/definitions/tripTypeItem" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
